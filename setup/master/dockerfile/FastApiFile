FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY sources/requirements_api.txt /tmp/requirements.txt

RUN python -m pip install --upgrade pip 

RUN set -eux; \
    python -m pip install --no-cache-dir --break-system-packages --ignore-installed -r /tmp/requirements.txt


RUN python -m pip install celery redis
RUN python -m pip install -e /OSIR/OSIR/src/osir_api
RUN python -m pip install -e /OSIR/OSIR/src/osir_lib
RUN python -m pip install -e /OSIR/OSIR/src/osir_service

EXPOSE 8502
