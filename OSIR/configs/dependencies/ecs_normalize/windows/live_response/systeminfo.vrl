# -----------------------------------------------------------------------------
# Windows systeminfo → ECS-ish
# Handles both English and French CSV headers
# -----------------------------------------------------------------------------

# Ensure .event exists
if !exists(.event) {
  .event = {}
}

# Keep raw event (once)
if !exists(.event.original) {
  .event.original = encode_json!(.)
}

# -----------------------------------------------------------------------------
# ECS scaffolding
# -----------------------------------------------------------------------------
.event.dataset  = "windows.systeminfo"
.event.module   = "windows"
.event.kind     = "state"
.event.category = ["host"]
.event.type     = ["info"]
.event.action   = "systeminfo"
.event.code     = "systeminfo"
.event.outcome  = "success"
.event.provider = "Windows Systeminfo"

# -----------------------------------------------------------------------------
# 1) Host name
#     EN: "Host Name"
#     FR: "Nom de l'hôte" (mojibake in sample: "Nom de l'h�te")
# -----------------------------------------------------------------------------
host_name = null

if exists(."Host Name") {
  host_name = to_string!(del(."Host Name"))
} else if exists(."Nom de l'hôte") {
  host_name = to_string!(del(."Nom de l'hôte"))
} else if exists(."Nom de l'h�te") {
  host_name = to_string!(del(."Nom de l'h�te"))
}

if host_name != null && host_name != "" {
  .host.name = host_name
}

# -----------------------------------------------------------------------------
# 2) OS name
#     EN: "OS Name"
#     FR: "Nom du système d'exploitation" (sample mojibake: "Nom du syst�me d'exploitation")
# -----------------------------------------------------------------------------
os_name_raw = null

if exists(."OS Name") {
  os_name_raw = to_string!(del(."OS Name"))
} else if exists(."Nom du système d'exploitation") {
  os_name_raw = to_string!(del(."Nom du système d'exploitation"))
} else if exists(."Nom du syst�me d'exploitation") {
  os_name_raw = to_string!(del(."Nom du syst�me d'exploitation"))
}

if os_name_raw != null && os_name_raw != "" {
  .host.os.name = os_name_raw
}

# -----------------------------------------------------------------------------
# 3) OS version
#     EN: "OS Version"
#     FR: "Version du système" (sample: "Version du syst�me")
#     Example: "10.0.19045 N/A Build 19045"
# -----------------------------------------------------------------------------
os_version_raw = null

if exists(."OS Version") {
  os_version_raw = to_string!(del(."OS Version"))
} else if exists(."Version du système") {
  os_version_raw = to_string!(del(."Version du système"))
} else if exists(."Version du syst�me") {
  os_version_raw = to_string!(del(."Version du syst�me"))
}

if os_version_raw != null && os_version_raw != "" {
  # Try to extract numeric version as first token
  parts = split!(os_version_raw, " ")
  if length(parts) > 0 {
    .host.os.version = to_string!(parts[0])
  } else {
    .host.os.version = os_version_raw
  }
  .host.os.Ext.systeminfo.version_raw = os_version_raw
}

