# -----------------------------------------------------------------------------
# descriptions
# -----------------------------------------------------------------------------
if exists(.event.kind) && exists(.host.name) {
  .message = "Audit event of type " + to_string!(.event.kind) + " occurred on " + to_string!(.host.name)
}
if .event.kind == "ADD_GROUP" && exists(.host.name) {
  .message = "Group was added on " + to_string!(.host.name)
}
if .event.kind == "SOFTWARE_UPDATE" && exists(.host.name) {
  .message = "Software update performed on " + to_string!(.host.name)
}
if .event.kind == "SYSTEM_BOOT" && exists(.host.name) {
  .message = "System booted on " + to_string!(.host.name)
}
if .event.kind == "SYSTEM_SHUTDOWN" && exists(.host.name) {
  .message = "System shutdown initiated on " + to_string!(.host.name)
}
if .event.kind == "DAEMON_START" && exists(.process.pid) && exists(.host.name) {
  .message = "Audit daemon started (PID: " + to_string!(.process.pid) + ") on " + to_string!(.host.name)
}
if .event.kind == "DAEMON_END" && exists(.process.pid) && exists(.host.name) {
  .message = "Audit daemon stopped (PID: " + to_string!(.process.pid) + ") on " + to_string!(.host.name)
}
if .event.kind == "ADD_USER" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "User " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") was added on " + to_string!(.host.name)
}
if .event.kind == "CONFIG_CHANGE" && exists(.audit.message) && exists(.audit.old) && exists(.host.name) {
  .message = "Audit configuration changed: " + to_string!(.audit.message) + " (old=" + to_string!(.audit.old) + ") on " + to_string!(.host.name)
}
if .event.kind == "CRED_ACQ" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "Credentials acquired by user " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") on " + to_string!(.host.name)
}
if .event.kind == "CRED_DISP" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "Credentials disposed by user " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") on " + to_string!(.host.name)
}
if .event.kind == "CRED_REFR" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "Credentials refreshed by user " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") on " + to_string!(.host.name)
}
if .event.kind == "CRYPTO_KEY_USER" && exists(.process.executable) && exists(.process.pid) && exists(.host.name) {
  .message = "Crypto key used by process " + to_string!(.process.executable) + " (PID: " + to_string!(.process.pid) + ") on " + to_string!(.host.name)
}
if .event.kind == "CRYPTO_SESSION" && exists(.process.executable) && exists(.process.pid) && exists(.host.name) {
  .message = "Crypto session established by process " + to_string!(.process.executable) + " (PID: " + to_string!(.process.pid) + ") on " + to_string!(.host.name)
}
if .event.kind == "LOGIN" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "User " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") logged in on " + to_string!(.host.name)
}
if .event.kind == "USER_AUTH" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "User " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") authenticated on " + to_string!(.host.name)
}
if .event.kind == "USER_LOGIN" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "User " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") logged in on " + to_string!(.host.name)
}
if .event.kind == "USER_LOGOUT" && exists(.user.name) && exists(.user.id) && exists(.host.name) {
  .message = "User " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ") logged out from " + to_string!(.host.name)
}
if .event.kind == "USER_CMD" && exists(.process.command_line) && exists(.user.name) && exists(.user.id) {
  .message = "Command " + to_string!(.process.command_line) + " executed by user " + to_string!(.user.name) + " (UID: " + to_string!(.user.id) + ")"
}
if .event.kind == "SERVICE_START" && exists(.process.name) && exists(.process.pid) && exists(.host.name) {
  .message = "Service " + to_string!(.process.name) + " started (PID: " + to_string!(.process.pid) + ") on " + to_string!(.host.name)
}
if .event.kind == "SERVICE_STOP" && exists(.process.name) && exists(.process.pid) && exists(.host.name) {
  .message = "Service " + to_string!(.process.name) + " stopped (PID: " + to_string!(.process.pid) + ") on " + to_string!(.host.name)
}
if .event.kind == "SYSCALL" && exists(.event.action) && exists(.process.name) && exists(.process.pid) && exists(.host.name) {
  .message = "Syscall " + to_string!(.event.action) + " executed by process " + to_string!(.process.name) + " (PID: " + to_string!(.process.pid) + ") on " + to_string!(.host.name)
}
if .event.kind == "AVC" && exists(.audit.message) && exists(.audit.scontext) && exists(.audit.tcontext) && exists(.audit.tclass) && exists(.host.name) {
  .message = "AVC denial: " + to_string!(.audit.message) + " (scontext=" + to_string!(.audit.scontext) + ", tcontext=" + to_string!(.audit.tcontext) + ", tclass=" + to_string!(.audit.tclass) + ") on " + to_string!(.host.name)
}