  if !is_array(.relationships) { .relationships = [] }
  .relationships = push!(.relationships, {"source": to_string!(.user.name), "target": to_string!(.action.properties.ObjectName), "type": "modified registry value from"})
}
if .action.id == 4662 && .event.provider == "Microsoft-Windows-Security-Auditing" && exists(.user.domain) && exists(.user.name) && exists(.action.properties.ObjectName) && exists(.host.name) {
