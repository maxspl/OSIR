# set_channel
# -----------------------------------------------------------------------------
if exists(.Event.System.Channel) {
  .event.dataset = to_string!(.Event.System.Channel)
}

# -----------------------------------------------------------------------------
# set_dll
# -----------------------------------------------------------------------------
if exists(.Event.EventData.ImageLoaded) {
  .dll.path = .Event.EventData.ImageLoaded
}
if exists(.Event.EventData.OriginalFileName) {
  .dll.name = .Event.EventData.OriginalFileName
}
if exists(.parsed_hashes_kv.IMPHASH) {
  .dll.pe.imphash = .parsed_hashes_kv.IMPHASH
}
if !exists(.dll.pe.imphash) {
  if exists(.parsed_hashes_kv_2.IMPHASH) {
    .dll.pe.imphash = .parsed_hashes_kv_2.IMPHASH
  }
}
if exists(.parsed_hashes_kv.MD5) {
  .dll.hash.md5 = .parsed_hashes_kv.MD5
}
if !exists(.dll.hash.md5) {
  if exists(.parsed_hashes_kv_2.MD5) {
    .dll.hash.md5 = .parsed_hashes_kv_2.MD5
  }
}
if exists(.parsed_hashes_kv.SHA256) {
  .dll.hash.sha256 = .parsed_hashes_kv.SHA256
}
if !exists(.dll.hash.sha256) {
  if exists(.parsed_hashes_kv_2.SHA256) {
    .dll.hash.sha256 = .parsed_hashes_kv_2.SHA256
  }
}

# -----------------------------------------------------------------------------
# set_file
# -----------------------------------------------------------------------------
if exists(.Event.EventData.LocalName) {
  if exists(.Event.EventData.LocalName) {
    .file.path = .Event.EventData.LocalName
  }
  if exists(.Event.EventData.LocalName) {
    .file.name = basename!(.Event.EventData.LocalName)
  }
}
if !exists(.file.path) {
  if exists(.Event.EventData.TargetFilename) {
    .file.path = .Event.EventData.TargetFilename
  }
  if exists(.Event.EventData.TargetFilename) {
    .file.name = basename!(.Event.EventData.TargetFilename)
  }
}
if exists(.Event.EventData.jobOwner) {
  .file.owner = .Event.EventData.jobOwner
}
if exists(.Event.EventData.CreationUtcTime) {
  if exists(.Event.EventData.CreationUtcTime) {
    .file.created = to_string!(.Event.EventData.CreationUtcTime)
  }
}
if exists(.Event.EventData.fileLength) {
  .file.size = .Event.EventData.fileLength
}
if .Event.System.Provider == "Microsoft-Windows-Bits-Client" && includes([59, 60], .event.id) {
  if exists(.Event.EventData.name) {
    .file.name = basename!(.Event.EventData.name)
