# -----------------------------------------------------------------------------
# Sysinternals Tcpvcon 
#   Input fields:
#     type, protocol, process_name, pid, state,
#     local_address, remote_address
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Keep raw event 
# -----------------------------------------------------------------------------
if !exists(.event) || !exists(.event.original) {
    .event.original = encode_json!(.)
}

# -----------------------------------------------------------------------------
# Basic ECS scaffolding
# -----------------------------------------------------------------------------

.event.dataset  = "windows.tcpvcon"
.event.module   = "windows"

# Connection snapshot on the host
.event.kind     = "state"
.event.category = ["network"]
.event.type     = ["info", "connection"]

.event.outcome  = "success"
.event.provider = "Sysinternals Tcpvcon"

# We'll refine network.type below based on IP family
.network.protocol = "ip"

# -----------------------------------------------------------------------------
# Basic event classification from "type"
# -----------------------------------------------------------------------------

rec_type = null
if exists(.type) {
    rec_type = to_string!(del(.type))
    .event.code   = rec_type
    .event.action = downcase(rec_type)
}

# -----------------------------------------------------------------------------
# Protocol → network.transport / protocol
# -----------------------------------------------------------------------------

if exists(.protocol) {
    proto_raw = to_string!(del(.protocol))
    proto_l   = downcase(proto_raw)

    .network.transport = proto_l
    .network.protocol  = proto_l
}

# -----------------------------------------------------------------------------
# Process info
# -----------------------------------------------------------------------------

if exists(.process_name) {
    .process.name = to_string!(del(.process_name))
}

if exists(.pid) {
    pid_raw = to_string!(del(.pid))
    pid_int = parse_int(pid_raw) ?? null

    if pid_int != null {
        .process.pid = pid_int
    } else {
        .process.pid = pid_raw
    }
}

# -----------------------------------------------------------------------------
# Connection state
# -----------------------------------------------------------------------------

if exists(.state) {
    state_raw = to_string!(del(.state))
    state_l   = downcase(state_raw)

    # Keep raw state under network.Ext
    .network.Ext.tcp_state = state_raw

    # Use state as a better event.action than "tcpvcon_connection"
    .event.action = state_l

    # Simple direction hint for listeners
    if state_l == "listening" {
        .network.direction = "ingress"
    }
}

# -----------------------------------------------------------------------------
# Local / remote addresses → source/destination
# -----------------------------------------------------------------------------

local_ip  = null
remote_ip = null

if exists(.local_address) {
    local_ip = to_string!(del(.local_address))
    if local_ip != "" {
        .source.ip = local_ip
    }
}

if exists(.remote_address) {
    remote_ip = to_string!(del(.remote_address))
    if remote_ip != "" {
        .destination.ip = remote_ip
    }
}

# Infer IP family for network.type
ip_sample = null
if local_ip != null && local_ip != "" {
    ip_sample = local_ip
} else if remote_ip != null && remote_ip != "" {
    ip_sample = remote_ip
}

if ip_sample != null {
    ip_str = to_string!(ip_sample)
    if contains(ip_str, ":") {
        .network.type = "ipv6"
    } else {
        .network.type = "ipv4"
    }
}
