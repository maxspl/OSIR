# -----------------------------------------------------------------------------
# 17) Original Install Date / System Boot Time → .timestamp
#
# We prefer System Boot Time (systeminfo snapshot ≈ current boot),
# and fall back to Original Install Date if boot time parsing fails.
#
# EN: "Original Install Date", "System Boot Time"
# FR: "Date d'installation originale", "Heure de démarrage du système"
# -----------------------------------------------------------------------------
ts_value  = null
ts_source = null

# Common helper: parse both US (MM/DD/YYYY, 12h) and EU (DD/MM/YYYY, 24h)
# NOTE: must be inline, so we just duplicate the pattern where needed.

# 17.1 System Boot Time (preferred)
boot_raw = null
if exists(."System Boot Time") {
  boot_raw = to_string!(del(."System Boot Time"))
} else if exists(."Heure de démarrage du système") {
  boot_raw = to_string!(del(."Heure de démarrage du système"))
} else if exists(."Heure de d�marrage du syst�me") {
  boot_raw = to_string!(del(."Heure de d�marrage du syst�me"))
}

if boot_raw != null && boot_raw != "" && ts_value == null {
  ts = parse_timestamp(boot_raw, "%m/%d/%Y, %I:%M:%S %p") ?? parse_timestamp(boot_raw, "%d/%m/%Y, %T") ?? null
  if ts != null {
    ts_value  = ts
    ts_source = "systeminfo_boot_time"
  } else {
    .host.Ext.systeminfo.boot_time_raw = boot_raw
  }
}

# 17.2 Original Install Date (fallback)
inst_raw = null
if exists(."Original Install Date") {
  inst_raw = to_string!(del(."Original Install Date"))
} else if exists(."Date d'installation originale") {
  inst_raw = to_string!(del(."Date d'installation originale"))
} else if exists(."Date d'installation originale") {
  inst_raw = to_string!(del(."Date d'installation originale"))
}

if inst_raw != null && inst_raw != "" {
  # Store raw regardless
  .host.os.Ext.systeminfo.install_date_raw = inst_raw

  if ts_value == null {
    its = parse_timestamp(inst_raw, "%m/%d/%Y, %I:%M:%S %p") ?? parse_timestamp(inst_raw, "%d/%m/%Y, %T") ?? null
    if its != null {
      ts_value  = its
      ts_source = "systeminfo_original_install_date"
    }
  }
}

# 17.3 Apply timestamp if we resolved one
if ts_value != null {
  .timestamp = ts_value

  if !exists(.event.created) {
    .event.created = ts_value
  }

  .event.Ext.timestamp_source = ts_source
}
