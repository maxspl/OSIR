FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY sources/requirements_api.txt /tmp/requirements.txt

RUN python -m pip install --upgrade pip 

RUN set -eux; \
    python -m pip install --no-cache-dir --break-system-packages --ignore-installed -r /tmp/requirements.txt


RUN python -m pip install celery redis

EXPOSE 8502

COPY sources/api_entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["uvicorn", "osir_api.OsirApi:app", "--host", "0.0.0.0", "--port", "8502"]
