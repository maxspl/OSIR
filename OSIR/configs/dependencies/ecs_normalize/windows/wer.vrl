if exists(."PS_Application_Version") {
    .process.pe.file_version = del(."PS_Application_Version")
} else if exists(."PS_Version_de_l’application") {
    .process.pe.file_version = del(."PS_Version_de_l’application")
}

if exists(."PS_Application_Timestamp") {
    .wer.ps_application_timestamp = del(."PS_Application_Timestamp")
}
if exists(."PS_Horodatage_de_l’application") {
    .wer.ps_application_timestamp_fr = del(."PS_Horodatage_de_l’application")
}

if exists(."PS_FileVersionOfSystemManagementAutomation") {
    .wer.ps_file_version_of_sma = del(."PS_FileVersionOfSystemManagementAutomation")
}

if exists(."PS_RevisionID") {
    .wer.ps_revision_id = del(."PS_RevisionID")
}

# FR parameters 1–4
if exists(."PS_Paramètre 1") {
    .wer.ps_param_1 = del(."PS_Paramètre 1")
}
if exists(."PS_Paramètre 2") {
    .wer.ps_param_2 = del(."PS_Paramètre 2")
}
if exists(."PS_Paramètre 3") {
    .wer.ps_param_3 = del(."PS_Paramètre 3")
}
if exists(."PS_Paramètre 4") {
    .wer.ps_param_4 = del(."PS_Paramètre 4")
}

# -----------------------------------------------------------------------------
# Dynamic signatures / Ns* / ProcessMetadata / state
# -----------------------------------------------------------------------------

if exists(.dynamic_signatures) {
    .wer.dynamic_signatures = del(.dynamic_signatures)
}
if exists(.dynamic_signatures_raw) {
    .wer.dynamic_signatures_raw = del(.dynamic_signatures_raw)
}

# Ns[0..4].Name/Value (FR only)
ns = []

if exists(."Ns[0].Name") {
    ns0 = {
        "name": del(."Ns[0].Name"),
        "value": del(."Ns[0].Value")
    }
    ns = push(ns, ns0)
}
if exists(."Ns[1].Name") {
    ns1 = {
        "name": del(."Ns[1].Name"),
        "value": del(."Ns[1].Value")
    }
    ns = push(ns, ns1)
}
if exists(."Ns[2].Name") {
    ns2 = {
        "name": del(."Ns[2].Name"),
        "value": del(."Ns[2].Value")
    }
    ns = push(ns, ns2)
}
if exists(."Ns[3].Name") {
    ns3 = {
        "name": del(."Ns[3].Name"),
        "value": del(."Ns[3].Value")
    }
    ns = push(ns, ns3)
}
if exists(."Ns[4].Name") {
    ns4 = {
        "name": del(."Ns[4].Name"),
        "value": del(."Ns[4].Value")
    }
    ns = push(ns, ns4)
}

if length(ns) > 0 {
    .wer.ns = ns
}

# Ns partner / group (both FR + EN)
if exists(.NsPartner) {
    .wer.ns_partner = del(.NsPartner)
}
if exists(.NsGroup) {
    .wer.ns_group = del(.NsGroup)
}

# ProcessMetadata[0..5].Key/Value
pm = []

if exists(."ProcessMetadata[0].Key") {
    pm0 = {
        "key": del(."ProcessMetadata[0].Key"),
        "value": del(."ProcessMetadata[0].Value")
    }
    pm = push(pm, pm0)
}
if exists(."ProcessMetadata[1].Key") {
    pm1 = {
        "key": del(."ProcessMetadata[1].Key"),
        "value": del(."ProcessMetadata[1].Value")
    }
    pm = push(pm, pm1)
}
if exists(."ProcessMetadata[2].Key") {
    pm2 = {
        "key": del(."ProcessMetadata[2].Key"),
        "value": del(."ProcessMetadata[2].Value")
    }
    pm = push(pm, pm2)
}
if exists(."ProcessMetadata[3].Key") {
    pm3 = {
        "key": del(."ProcessMetadata[3].Key"),
        "value": del(."ProcessMetadata[3].Value")
    }
    pm = push(pm, pm3)
}
if exists(."ProcessMetadata[4].Key") {
    pm4 = {
        "key": del(."ProcessMetadata[4].Key"),
        "value": del(."ProcessMetadata[4].Value")
    }
    pm = push(pm, pm4)
}
if exists(."ProcessMetadata[5].Key") {
    pm5 = {
        "key": del(."ProcessMetadata[5].Key"),
        "value": del(."ProcessMetadata[5].Value")
    }
    pm = push(pm, pm5)
}

if length(pm) > 0 {
    .wer.process_metadata = pm
}

# state (WER internal) → move away from ECS .event.state
if exists(.state) {
    .wer.state = del(.state)
}

# -----------------------------------------------------------------------------
# Loaded modules
# -----------------------------------------------------------------------------

if exists(.loaded_modules) {
    .wer.loaded_modules = del(.loaded_modules)
}

# -----------------------------------------------------------------------------
# Files (File[0..6].*)
# -----------------------------------------------------------------------------

files = []

# 0..6
# index 0
if exists(."File[0].Path") || exists(."File[0].Original.Path") || exists(."File[0].CabName") {
    f0 = {}
    if exists(."File[0].Path")           { f0.path          = del(."File[0].Path") }
    if exists(."File[0].Original.Path")  { f0.original_path = del(."File[0].Original.Path") }
    if exists(."File[0].Type")           { f0.type          = del(."File[0].Type") }
    if exists(."File[0].CabName")        { f0.cab_name      = del(."File[0].CabName") }
    if exists(."File[0].Flags")          { f0.flags         = del(."File[0].Flags") }
    files = push(files, f0)
}

# index 1
if exists(."File[1].Path") || exists(."File[1].Original.Path") || exists(."File[1].CabName") {
    f1 = {}
    if exists(."File[1].Path")           { f1.path          = del(."File[1].Path") }
    if exists(."File[1].Original.Path")  { f1.original_path = del(."File[1].Original.Path") }
    if exists(."File[1].Type")           { f1.type          = del(."File[1].Type") }
    if exists(."File[1].CabName")        { f1.cab_name      = del(."File[1].CabName") }
    if exists(."File[1].Flags")          { f1.flags         = del(."File[1].Flags") }
    files = push(files, f1)
}

# index 2
if exists(."File[2].Path") || exists(."File[2].Original.Path") || exists(."File[2].CabName") {
    f2 = {}
    if exists(."File[2].Path")           { f2.path          = del(."File[2].Path") }
    if exists(."File[2].Original.Path")  { f2.original_path = del(."File[2].Original.Path") }
    if exists(."File[2].Type")           { f2.type          = del(."File[2].Type") }
    if exists(."File[2].CabName")        { f2.cab_name      = del(."File[2].CabName") }
    if exists(."File[2].Flags")          { f2.flags         = del(."File[2].Flags") }
    files = push(files, f2)
}

# index 3
if exists(."File[3].Path") || exists(."File[3].Original.Path") || exists(."File[3].CabName") {
    f3 = {}
    if exists(."File[3].Path")           { f3.path          = del(."File[3].Path") }
    if exists(."File[3].Original.Path")  { f3.original_path = del(."File[3].Original.Path") }
    if exists(."File[3].Type")           { f3.type          = del(."File[3].Type") }
    if exists(."File[3].CabName")        { f3.cab_name      = del(."File[3].CabName") }
    if exists(."File[3].Flags")          { f3.flags         = del(."File[3].Flags") }
    files = push(files, f3)
}

# index 4
if exists(."File[4].Path") || exists(."File[4].Original.Path") || exists(."File[4].CabName") {
    f4 = {}
    if exists(."File[4].Path")           { f4.path          = del(."File[4].Path") }
    if exists(."File[4].Original.Path")  { f4.original_path = del(."File[4].Original.Path") }
    if exists(."File[4].Type")           { f4.type          = del(."File[4].Type") }
    if exists(."File[4].CabName")        { f4.cab_name      = del(."File[4].CabName") }
    if exists(."File[4].Flags")          { f4.flags         = del(."File[4].Flags") }
    files = push(files, f4)
}

# index 5
if exists(."File[5].Path") || exists(."File[5].Original.Path") || exists(."File[5].CabName") {
    f5 = {}
    if exists(."File[5].Path")           { f5.path          = del(."File[5].Path") }
    if exists(."File[5].Original.Path")  { f5.original_path = del(."File[5].Original.Path") }
    if exists(."File[5].Type")           { f5.type          = del(."File[5].Type") }
    if exists(."File[5].CabName")        { f5.cab_name      = del(."File[5].CabName") }
    if exists(."File[5].Flags")          { f5.flags         = del(."File[5].Flags") }
    files = push(files, f5)
}

# index 6
if exists(."File[6].Path") || exists(."File[6].Original.Path") || exists(."File[6].CabName") {
    f6 = {}
    if exists(."File[6].Path")           { f6.path          = del(."File[6].Path") }
    if exists(."File[6].Original.Path")  { f6.original_path = del(."File[6].Original.Path") }
    if exists(."File[6].Type")           { f6.type          = del(."File[6].Type") }
    if exists(."File[6].CabName")        { f6.cab_name      = del(."File[6].CabName") }
    if exists(."File[6].Flags")          { f6.flags         = del(."File[6].Flags") }
    files = push(files, f6)
}

if length(files) > 0 {
    .wer.files = files
}

# -----------------------------------------------------------------------------
# Miscellaneous / remaining WER metadata
# -----------------------------------------------------------------------------

if exists(.ReportType) {
    .wer.report_type = del(.ReportType)
}
if exists(.ReportIdentifier) {
    .wer.report_identifier = del(.ReportIdentifier)
}
if exists(.IntegratorReportIdentifier) {
    .wer.integrator_report_identifier = del(.IntegratorReportIdentifier)
}
if exists(.MetadataHash) {
    .wer.metadata_hash = del(.MetadataHash)
}
if exists(.ReportFlags) {
    .wer.report_flags = del(.ReportFlags)
}
if exists(.ReportStatus) {
    .wer.report_status = del(.ReportStatus)
}
if exists(.ServiceSplit) {
    .wer.service_split = del(.ServiceSplit)
}
if exists(.UserImpactVector) {
    .wer.user_impact_vector = del(.UserImpactVector)
}
if exists(.Version) {
    .wer.version = del(.Version)
}

# UI[3..10] (we already consumed UI[2] as command_line)
ui = {}
if exists(."UI[3]")  { ui."3"  = del(."UI[3]") }
if exists(."UI[4]")  { ui."4"  = del(."UI[4]") }
if exists(."UI[5]")  { ui."5"  = del(."UI[5]") }
if exists(."UI[6]")  { ui."6"  = del(."UI[6]") }
if exists(."UI[7]")  { ui."7"  = del(."UI[7]") }
if exists(."UI[8]")  { ui."8"  = del(."UI[8]") }
if exists(."UI[9]")  { ui."9"  = del(."UI[9]") }
if exists(."UI[10]") { ui."10" = del(."UI[10]") }

if length(ui) > 0 {
    .wer.ui = ui
}
